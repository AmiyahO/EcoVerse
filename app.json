{
  "expo": {
    "name": "EcoVerse",
    "slug": "ecoverse",
    "owner": "amirahy",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "ecoverse",
    "backgroundColor": "#0B0F0C",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#2a7828",
      "dark": {
        "backgroundColor": "#05220c"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.amirah.ecoverse",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amirah.ecoverse"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-google-signin/google-signin",
      "expo-health-connect",
      "react-native-health-connect",
      "@react-native-community/datetimepicker",
      "expo-notifications",
      "expo-audio",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c0b98d74-44ad-4521-a482-2f2eaf83c89f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c0b98d74-44ad-4521-a482-2f2eaf83c89f"
    }
  }
}
