// app.json
{
  "expo": {
    "name": "EcoVerse",
    "slug": "ecoverse",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ecoverse",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/icon.png",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE",
      "dark": {
        "image": "./assets/images/icon.png",
        "backgroundColor": "#000000"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#E6F4FE"
      },
      "package": "com.anonymous.ecoverse"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.ecoverse"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
